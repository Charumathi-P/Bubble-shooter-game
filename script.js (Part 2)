function drawGrid(){

    for(let r=0;r<ROWS;r++){

        for(let c=0;c<COLS;c++){

            let b=grid[r][c];

            if(b){

                ctx.beginPath();

                ctx.arc(
                    b.x,
                    b.y,
                    b.radius,
                    0,
                    Math.PI*2
                );

                ctx.fillStyle=b.color;
                ctx.fill();

                ctx.strokeStyle="#fff";
                ctx.stroke();

            }

        }

    }

}
